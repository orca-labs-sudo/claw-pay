# Coinbase CDP v2 — aus portal.cdp.coinbase.com → API Keys
CDP_API_KEY_ID=
CDP_API_KEY_SECRET=
CDP_WALLET_SECRET=

# Facilitator Account (EVM Adresse des Server Wallets auf Base)
FACILITATOR_ADDRESS=

# Provision
PROVISION_PERCENT=3
ESCROW_TIMEOUT_HOURS=48

# Network
NETWORK_ID=base-sepolia
# NETWORK_ID=base-mainnet  # nach erfolgreichem Testnet-Test

# Server
PORT=8000

# Admin Dashboard (https://deine-domain.org/admin)
ADMIN_USER=admin
ADMIN_PASS=changeme

